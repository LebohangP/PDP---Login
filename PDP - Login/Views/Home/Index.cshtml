@{
    ViewData["Title"] = "PDP System";
}

<section class="hero">
    <h1>Manage Personal Development Plans Efficiently</h1>
    <p>Submit, review, and approve employee PDPs in one system.</p>
    <a href="/Account/Login" class="btn">Get Started</a>
</section>

<section class="section">
    <h2>What is a PDP?</h2>
    <p>
        A Personal Development Plan (PDP) is an annual document where employees outline
        their goals, objectives, and development plans. This system simplifies submission
        and approval between employees and managers.
    </p>
</section>

<section class="section">
    <h2>Key Features</h2>
    <div class="features">
        <div class="card">
            <h3>Easy Submission</h3>
            <p>Employees submit PDPs quickly through a simple interface.</p>
        </div>

        <div class="card">
            <h3>Manager Review</h3>
            <p>Managers approve or decline PDPs with feedback.</p>
        </div>

        <div class="card">
            <h3>Status Tracking</h3>
            <p>Track approval progress in real time.</p>
        </div>
    </div>
</section>

<section class="section">
    <h2>How It Works</h2>
    <ul class="workflow">
        <li>1. Employee submits PDP</li>
        <li>2. Manager reviews</li>
        <li>3. Approve or decline</li>
        <li>4. Employee updates if needed</li>
    </ul>
</section>

<section class="cta">
    <h2>Start Managing PDPs Today</h2>
    <a href="/Account/Login" class="btn">Login</a>
</section>