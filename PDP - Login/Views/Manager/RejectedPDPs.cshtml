@model List<PDP___Login.Models.PDP>

<h2 class="text-danger mb-3">Rejected PDPs</h2>

<table class="table table-bordered table-striped">
    <thead class="table-danger">
        <tr>
            <th>Employee</th>
            <th>Title</th>
            <th>Status</th>
            <th>File</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var pdp in Model)
        {
            <tr>
                <td>@pdp.Employee?.FirstName @pdp.Employee?.LastName</td>

                <td>@pdp.Title</td>

                <td>
                    <span class="badge bg-danger">@pdp.Status</span>
                </td>

                <td>
                    @if (pdp.Files != null && pdp.Files.Any())
                    {
                        <a href="@pdp.Files.First().FilePath"
                           target="_blank"
                           class="btn btn-sm btn-primary">
                            View PDF
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">No file</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
