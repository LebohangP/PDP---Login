@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager



<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Inter', sans-serif;
        margin: 0;
        background: #f8fafc;
        color: #1e293b;
    }

    header {
        background: #0f172a;
        color: white;
        padding: 25px;
        text-align: center;
    }

    .container {
        max-width: 1200px;
        margin: auto;
        padding: 20px;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    a.button {
        background: #2563eb;
        color: white;
        padding: 10px 16px;
        border-radius: 6px;
        text-decoration: none;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }

    .card {
        background: white;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 6px 16px rgba(0,0,0,0.05);
        text-align: center;
    }

    canvas {
        max-height: 220px;
    }
</style>


<body>

    <header>
        <h1>Personal Development Plan</h1>
        <p>Department Training Insights</p>
    </header>

    <div class="container">

        <div class="top-bar">
            <h2>Department Overview</h2>
            <a class="nav-link text-dark" asp-area="" asp-controller="Manager" asp-action="Submissions">Submitted PDPs</a>
        </div>

        <!-- Department Doughnut Charts -->
        <div class="grid">

            <div class="card">
                <h3>ICT Department</h3>
                <canvas id="ictChart"></canvas>
            </div>

            <div class="card">
                <h3>HR Department</h3>
                <canvas id="hrChart"></canvas>
            </div>

            <div class="card">
                <h3>Finance Department</h3>
                <canvas id="financeChart"></canvas>
            </div>

            <div class="card">
                <h3>Operations Department</h3>
                <canvas id="opsChart"></canvas>
            </div>

        </div>

        <!-- Line Chart -->
        <div class="card" style="margin-top:20px;">
            <h3>Development Trend</h3>
            <canvas id="lineChart"></canvas>
        </div>

    </div>

    <script>
        //creating a function for the number of PDP submissions
        function getDepartmentCounts() {
          const data = JSON.parse(localStorage.getItem("pdpSubmissions")) || [];
           //sets the submissions to 0 since there are no submissions
          const counts = {
            ICT: 0,
            HR: 0,
            Finance: 0,
            Operations: 0
          };
           //increments for every submission
          data.forEach(item => {
            if (counts[item.department] !== undefined) {
              counts[item.department]++;
            }
          });

          return counts;
        }

        const deptData = getDepartmentCounts();

        // This is for the doghnut charts for people that have submitted their PDPs per department
        new Chart(document.getElementById("ictChart"), {
          type: 'doughnut',
          data: {
            labels: ['Submitted', 'Remaining'],
            datasets: [{
              data: [deptData.ICT, 50 - deptData.ICT],
              backgroundColor: ['#3b82f6', '#e5e7eb']
            }]
          }
        });

        new Chart(document.getElementById("hrChart"), {
          type: 'doughnut',
          data: {
            labels: ['Submitted', 'Remaining'],
            datasets: [{
              data: [deptData.HR, 50 - deptData.HR],
              backgroundColor: ['#10b981', '#e5e7eb']
            }]
          }
        });

        new Chart(document.getElementById("financeChart"), {
          type: 'doughnut',
          data: {
            labels: ['Submitted', 'Remaining'],
            datasets: [{
              data: [deptData.Finance, 50 - deptData.Finance],
              backgroundColor: ['#f59e0b', '#e5e7eb']
            }]
          }
        });

        new Chart(document.getElementById("opsChart"), {
          type: 'doughnut',
          data: {
            labels: ['Submitted', 'Remaining'],
            datasets: [{
              data: [deptData.Operations, 50 - deptData.Operations],
              backgroundColor: ['#ef4444', '#e5e7eb']
            }]
          }
        });

        // 📈 Trend Chart (based on real submissions over time)
        const allData = JSON.parse(localStorage.getItem("pdpSubmissions")) || [];

        const monthlyCounts = {
          Jan: 0, Feb: 0, Mar: 0, Apr: 0, May: 0, Jun: 0
        };

        allData.forEach(item => {
          const month = new Date(item.time).toLocaleString('default', { month: 'short' });
          if (monthlyCounts[month] !== undefined) {
            monthlyCounts[month]++;
          }
        });

        new Chart(document.getElementById("lineChart"), {
          type: 'line',
          data: {
            labels: Object.keys(monthlyCounts),
            datasets: [{
              label: 'PDP Submissions',
              data: Object.values(monthlyCounts),
              borderColor: '#2563eb',
              backgroundColor: 'rgba(37,99,235,0.1)',
              fill: true,
              tension: 0.4
            }]
          }
        });

    </script>
    </body>
