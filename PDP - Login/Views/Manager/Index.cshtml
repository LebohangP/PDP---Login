@model List<PDP___Login.Models.PDP>

<h2>Submitted PDPs</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Title</th>
            <th>Status</th>
            <th>File</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var pdp in Model)
        {
            <tr>
                <td>@pdp.Title</td>

                <td>
                    <span class="badge bg-warning">@pdp.Status</span>
                </td>

                <td>
                    @if (pdp.Files != null && pdp.Files.Any())
                    {
                        <a href="@pdp.Files.First().FilePath" target="_blank" class="btn btn-sm btn-primary">
                            View PDF
                        </a>
                    }
                </td>

                <td>
                    <a asp-action="UpdateStatus"
                       asp-route-id="@pdp.Id"
                       asp-route-status="Approved"
                       class="btn btn-success btn-sm">
                        Approve
                    </a>

                    <a asp-action="UpdateStatus"
                       asp-route-id="@pdp.Id"
                       asp-route-status="Rejected"
                       class="btn btn-danger btn-sm">
                        Reject
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>